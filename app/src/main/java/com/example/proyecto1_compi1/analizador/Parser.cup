precedence left SUMA, RESTA;
precedence left MULTI, DIVISION, MODULO;
precedence right POTENCIA;
precedence left MAYOR, MENOR, IGUALIGUAL, DIFERENTE;

start with inicio;

inicio ::=
    lista_elementos

;


lista_elementos ::=

    lista_elementos element:e
    {:

        ResultParser.currentForm.addElement(e);
    :}

    | element:e
    {:

        ResultParser.currentForm.addElement(e);
    :}
;

/*
elemento ::=
    seccion
    | pregunta
    | text_decl
    | table_decl
    | preguntas
;
*/


lista_valores ::=
    lista_valores:l COMA CADENA:c
    {:
        l.add(c.toString());
        RESULT = l;
    :}
    |
    CADENA:c
    {:
        ArrayList<String> lista = new ArrayList<>();
        lista.add(c.toString());
        RESULT = lista;
    :}
;




text_decl ::=
    TEXT CORCHETE_ABRE text_props:p CORCHETE_CIERRA
    {:

        TextModel text = new TextModel();

        for(PropertyItem prop : p) {
            text.addProperty(prop);
        }

        RESULT = text;
    :}
;

text_props ::=
    text_props:l COMA text_prop:p
    {:
        l.add(p);
        RESULT = l;
    :}
    | text_prop:l
    {:
        ArrayList<PropertyItem> list = new ArrayList<>();
        list.add(l);
        RESULT = list;
    :}
;

text_prop ::=

    CONTENT DOSPUNTOS CADENA:c
    {:
        RESULT = new PropertyItem("content", c);
    :}
    | WIDTH DOSPUNTOS ENTERO:n
    {:
        RESULT = new PropertyItem("width", n);
    :}
    | HEIGHT DOSPUNTOS ENTERO:n
    {:
        RESULT = new PropertyItem("height", n);
    :}
    | styles_block:s
    {:
        RESULT = new PropertyItem("styles", s);
    :}
    | LABEL DOSPUNTOS CADENA:c
    {:
        RESULT = new PropertyItem("label", c);
    :}
;



    /*-------------- PREGUNTAS MODIFICADO -------------------*/

    preguntas ::=
        open_q
        | drop_q
        | select_q
        | multiple_q
    ;

    open_q ::=
        OPENQUESTION CORCHETE_ABRE question_props:p CORCHETE_CIERRA
        {:
                System.out.println("SI ESTA EN OPEN");
                OpenQuestion open = new OpenQuestion();

                for(PropertyItem prop : p) {

                        open.addProperty(prop);

                }


                RESULT = open;

        :}
    ;

    drop_q ::=
        DROPQUESTION CORCHETE_ABRE question_props:p CORCHETE_CIERRA
        {:
                System.out.println("SI ESTA EN DROP");

                DropQuestion drop = new DropQuestion();

                for(PropertyItem prop : p) {

                        drop.addProperty(prop);

                }



                RESULT = drop;

        :}
    ;

    select_q ::=
        SELECTQUESTION CORCHETE_ABRE question_props:p CORCHETE_CIERRA
        {:

                System.out.println("SI ESTA EN SELECT ");
                SelectQuestion select = new SelectQuestion();

                for(PropertyItem prop : p) {

                        select.addProperty(prop);

                }


                RESULT = select;

        :}
    ;

    multiple_q ::=
        MULTIPLEQUESTION CORCHETE_ABRE question_props:p CORCHETE_CIERRA
        {:
                System.out.println("SI ESTA EN MULTIPLE");
                MultipleQuestion multiple = new MultipleQuestion();

                for(PropertyItem prop : p) {

                        multiple.addProperty(prop);

                }


                RESULT = multiple;

        :}
    ;

    question_props ::=
        question_props:l COMA question_prop:p
        {:
            l.add(p);
            RESULT = l;
        :}
        | question_prop:p
        {:
            ArrayList<PropertyItem> list = new ArrayList<>();
            list.add(p);
            RESULT = list;
        :}
    ;

    question_prop ::=
        LABEL DOSPUNTOS CADENA:c
        {:
            RESULT = new PropertyItem("label", c.toString().replace("\"", ""));
        :}
        | WIDTH DOSPUNTOS ENTERO:n
        {:
            RESULT = new PropertyItem("width", Integer.parseInt(n.toString()));
        :}
        | HEIGHT DOSPUNTOS ENTERO:n
        {:
            RESULT = new PropertyItem("height", Integer.parseInt(n.toString()));
        :}
        | OPTIONS DOSPUNTOS lista_opciones:o
        {:
            RESULT = new PropertyItem("options", o);
        :}
        | CORRECT DOSPUNTOS ENTERO:n
        {:
            RESULT = new PropertyItem("correct", Integer.parseInt(n.toString()));
        :}
        | styles_block:s
        {:
            RESULT = new PropertyItem("styles", s);
        :}
    ;

    lista_opciones ::=
        LLAVE_ABRE lista_strings:l LLAVE_CIERRA
        {:
            RESULT = l;
        :}
    ;

    lista_strings ::=
       lista_strings:l COMA CADENA:c
       {:
           l.add(c.toString().replace("\"", ""));
           RESULT = l;
       :}
       | CADENA:c
       {:
            ArrayList<String> list = new ArrayList<>();
            list.add(c.toString().replace("\"", ""));
            RESULT = list;
       :}
    ;
/*-------------------------------------------------------*/

lista_instrucciones ::=
        lista_instrucciones instruccion
        | instruccion
        ;

instruccion ::=
      pregunta
    | declaracion
    | table_decl
    | special_decl
    | draw_stmt
    | seccion
    | error PUNTOCOMA
      {:
          System.out.println("Se recuperó de error");
      :}
;

declaracion ::=

    VARIABLENUMBER VARIABLE:v IGUAL expresion:e PUNTOCOMA
    {:
        if (ResultParser.currentForm != null) {
            ResultParser.currentForm.addVariable(
                new VariableModel("number", v.toString(), e)
            );
        }
    :}

|   VARIABLESTRING VARIABLE:v IGUAL expresion:e PUNTOCOMA
    {:
        if (ResultParser.currentForm != null) {
            ResultParser.currentForm.addVariable(
                new VariableModel("string", v.toString(), e)
            );
        }
    :}

|   VARIABLESPECIAL VARIABLE:v IGUAL expresion:e PUNTOCOMA
    {:
        if (ResultParser.currentForm != null) {
            ResultParser.currentForm.addVariable(
                new VariableModel("special", v.toString(), e)
            );
        }
    :}
;

/* ------------------------- VARIABLE ESPECIAL -------------------------------------------*/
tipo_pregunta ::=
      OPENQUESTION {: RESULT = "OPENQUESTION"; :}
    | DROPQUESTION {: RESULT = "DROPQUESTION"; :}
    | SELECTQUESTION {: RESULT = "SELECTQUESTION"; :}
    | MULTIPLEQUESTION {: RESULT = "MULTIPLEQUESTION"; :}
;

/* ------------------ Declaración de variable special ------------- */

special_decl ::=
    SPECIAL VARIABLE:v IGUAL tipo_pregunta:t
    CORCHETE_ABRE special_props:props CORCHETE_CIERRA PUNTOCOMA
    {:
        java.util.ArrayList<java.lang.Integer> wildcards = new java.util.ArrayList<>();
        int idx = 0;
        for (PropertyItem item : props) {
            if (item.value instanceof String && "?".equals(item.value)) {
                wildcards.add(idx);
            }
            idx++;
        }

        SpecialQuestion sq = new SpecialQuestion(
            v.toString(),
            t,
            props,
            wildcards
        );

        if (ResultParser.currentForm != null) {
            ResultParser.currentForm.addSpecialQuestion(sq);
        }

        RESULT = sq;
    :}
    ;

special_props ::=
      special_props:l COMA special_prop:p   {: l.add(p); RESULT = l; :}
    | special_prop:p                        {:
        ArrayList<PropertyItem> lst = new ArrayList<>();
        lst.add(p);
        RESULT = lst;
      :}
    ;

special_prop ::=
      WIDTH DOSPUNTOS special_prop_value:v     {: RESULT = new PropertyItem("width", v); :}
    | HEIGHT DOSPUNTOS special_prop_value:v    {: RESULT = new PropertyItem("height", v); :}
    | LABEL DOSPUNTOS special_prop_value:v     {: RESULT = new PropertyItem("label", v); :}
    | VARIABLE:key DOSPUNTOS special_prop_value:v
      {: RESULT = new PropertyItem(key.toString().toLowerCase(), v); :}
    ;

special_prop_value ::=
      INTERROGACION                   {: RESULT = "?"; :}
    | expresion:e                     {: RESULT = e; :}
    ;


/* --------------------- DRAW -----------------------------------------*/

draw_call ::=
    VARIABLE:v PUNTO DRAW
    PARENTESIS_ABRE parametros:args PARENTESIS_CIERRA PUNTOCOMA
    {:
        if (ResultParser.formsModel == null) {
            ResultParser.formsModel = new FormsModel("UntitledForm");
        }

        SpecialQuestion sq = ResultParser.formsModel.findSpecialQuestion(v.toString());

        if (sq == null) {
            report_error("No existe variable special con nombre: " + v, null);
        }
        else if (args.size() != sq.getWildcardCount()) {
            report_error(
                "La llamada draw espera " + sq.getWildcardCount() +
                " argumento(s), pero se recibieron " + args.size(),
                null
            );
        }
        else {

            sq.setDrawArguments(args);

            QuestionModel q = sq.draw();

            if (q != null) {
                ResultParser.formsModel.addQuestion(q);
            }
        }

        RESULT = null;
    :}

    | VARIABLE:v PUNTO DRAW PARENTESIS_ABRE PARENTESIS_CIERRA PUNTOCOMA
    {:
        if (ResultParser.formsModel == null) {
            ResultParser.formsModel = new FormsModel("UntitledForm");
        }

        SpecialQuestion sq = ResultParser.formsModel.findSpecialQuestion(v.toString());

        if (sq != null) {

            QuestionModel q = sq.draw();

            if (q != null) {
                ResultParser.formsModel.addQuestion(q);
            }
        }

        RESULT = null;
    :}
;

draw_stmt ::=
    VARIABLE:v PUNTO DRAW
    PARENTESIS_ABRE parametros:args PARENTESIS_CIERRA PUNTOCOMA
    {:
        SpecialQuestion sq = ResultParser.currentForm.findSpecialQuestion(v.toString());

        if(sq != null) {

            sq.setDrawArguments(args);

            QuestionModel q = sq.draw();

            if(sq != null) {
                ResultParser.currentForm.addQuestion(q);
            }
        }
    :}
    | VARIABLE:v PUNTO DRAW PARENTESIS_ABRE PARENTESIS_CIERRA PUNTOCOMA
          {:
              if (ResultParser.currentForm == null) {
                  ResultParser.currentForm = new FormsModel("UntitledForm");
              }

              SpecialQuestion sq = ResultParser.currentForm.findSpecialQuestion(v.toString());

              if (sq != null) {

                  QuestionModel q = sq.draw();

                  if (q != null) {
                      ResultParser.currentForm.addQuestion(q);
                  }
              }

              RESULT = null;
          :}
;

draw_expr ::=
    VARIABLE:v PUNTO DRAW
    PARENTESIS_ABRE parametros:args PARENTESIS_CIERRA
    {:
        SpecialQuestion sq = ResultParser.currentForm.findSpecialQuestion(v.toString());

        if (sq != null) {

            sq.setDrawArguments(args);

            RESULT = sq.draw();
        } else {

            RESULT = null;
        }
    :}
;

/* ------------------------------------------------------------------------------*/





parametros ::=
    parametros:p COMA expresion:e
    {:
        p.add(e);
        RESULT = p;
    :}
    |
    expresion:e
    {:
        ArrayList<Object> list = new ArrayList<>();
        list.add(e);
        RESULT = list;
    :}
;

expresion ::=
        ENTERO:e
        {: RESULT = Integer.parseInt(e.toString()); :}

    | DECIMAL:d
        {: RESULT = Double.parseDouble(d.toString()); :}

    | CADENA:c
        {: RESULT = c.toString(); :}

    | VARIABLE:v
        {: RESULT = v.toString(); :}
;


/* ------------ PARA CREAR LAS TABLAS Y SECCIONES ---------------*/

element ::=
    section:s
    {:
        RESULT = s;
    :}
    | table:t
    {:
        RESULT = t;
    :}
    | text_decl:x
    {:
        RESULT = x;
    :}
    | open_q:o
    {:
        RESULT = o;
    :}
    | drop_q:d
    {:
        RESULT = d;
    :}
    | select_q:s
    {:
        RESULT = s;
    :}
    | multiple_q:m
    {:
        RESULT = m;
    :}
;

section ::=
    SECTION CORCHETE_ABRE section_props:p CORCHETE_CIERRA
    {:
        RESULT = new SectionsModel(p);
    :}
;

section_props ::=
    section_props:l COMA section_prop:p
    {:
        l.add(p);
        RESULT = l;
    :}
    | section_prop:p
    {:
        ArrayList list = new ArrayList();
        list.add(p);
        RESULT = list;
    :}
;

section_prop ::=
    WIDTH DOSPUNTOS ENTERO:n
    {:
        RESULT = new PropertyItem("width", n);
    :}
    | HEIGHT DOSPUNTOS ENTERO:n
    {:
        RESULT = new PropertyItem("height", n);
    :}
    | POINTX DOSPUNTOS ENTERO:n
    {:
        RESULT = new PropertyItem("pointX", n);
    :}
    | POINTY DOSPUNTOS ENTERO:n
    {:
        RESULT = new PropertyItem("pointY", n);
    :}
    | ORIENTATION DOSPUNTOS VERTICAL
    {:
        RESULT = new PropertyItem("orientation", "VERTICAL");
    :}
    | ORIENTATION DOSPUNTOS HORIZONTAL
    {:
        RESULT = new PropertyItem("orientation", "HORIZONTAL");
    :}
    | ELEMENTS DOSPUNTOS LLAVE_ABRE element_list:e LLAVE_CIERRA
    {:
        RESULT = new PropertyItem("elements", e);
    :}
    | styles_block:s
    {:
        RESULT = new PropertyItem("styles", s);
    :}
;

element_list ::=
    element_list:l COMA element:e
    {:
        l.add(e);
        RESULT = l;
    :}
    | element:e
    {:
        ArrayList list = new ArrayList();
        list.add(e);
        RESULT = list;
    :}
;

table ::=
    TABLE CORCHETE_ABRE table_props:tp CORCHETE_CIERRA
    {:
        RESULT = new TableModel(tp);
    :}
;

table_props ::=

      table_props:l COMA table_prop:p
        {:
            l.add(p);
            RESULT = l;
        :}

    | table_prop:p
        {:
            ArrayList list = new ArrayList();
            list.add(p);
            RESULT = list;
        :}
;

table_prop ::=

      WIDTH DOSPUNTOS ENTERO:n
        {: RESULT = new PropertyItem("width", n); :}

    | HEIGHT DOSPUNTOS ENTERO:n
        {: RESULT = new PropertyItem("height", n); :}

    | POINTX DOSPUNTOS ENTERO:n
        {: RESULT = new PropertyItem("pointX", n); :}

    | POINTY DOSPUNTOS ENTERO:n
        {: RESULT = new PropertyItem("pointY", n); :}

    | ELEMENTS DOSPUNTOS LLAVE_ABRE table_rows:r LLAVE_CIERRA
        {: RESULT = new PropertyItem("elements", r); :}

    | styles_block:s
        {: RESULT = new PropertyItem("styles", s); :}
;

table_rows ::=

      table_rows:l COMA table_row:r
        {:
            l.add(r);
            RESULT = l;
        :}

    | table_row:r
        {:
            ArrayList list = new ArrayList();
            list.add(r);
            RESULT = list;
        :}
;

table_row ::=
