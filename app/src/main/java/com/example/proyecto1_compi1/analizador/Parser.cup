            list.add(e);
            RESULT = list;
        :}
;

/*GRAMATICA PARA COLOR Y ESTILOS*/

styles_block ::=
    STYLES CORCHETE_ABRE style_list:s CORCHETE_CIERRA
    {: RESULT = s; :}
;

color_value ::=

   HEXCOLOR:h
        {: RESULT = new HexaColor(h.toString()); :}

    | PARENTESIS_ABRE ENTERO:r COMA ENTERO:g COMA ENTERO:b PARENTESIS_CIERRA
         {: RESULT = new RgbColor(
               Integer.parseInt(r.toString()),
               Integer.parseInt(g.toString()),
               Integer.parseInt(b.toString())
         ); :}

    | MENOR ENTERO:h COMA DECIMAL:s COMA DECIMAL:l MAYOR
        {: RESULT = new HslColor(
               Float.parseFloat(h.toString()),
               Float.parseFloat(s.toString()),
               Float.parseFloat(l.toString())
        ); :}

    | RED
        {: RESULT = BaseColor.RED; :}

    | BLUE
        {: RESULT = BaseColor.BLUE; :}

   | GREEN
        {: RESULT = BaseColor.GREEN; :}

   | PURPLE
        {: RESULT = BaseColor.PURPLE; :}

   | SKY
        {: RESULT = BaseColor.SKY; :}

   | YELLOW
        {: RESULT = BaseColor.YELLOW; :}

   | BLACK
        {: RESULT = BaseColor.BLACK; :}

   | WHITE
        {: RESULT = BaseColor.WHITE; :}
;

style_list ::=

      style_list:l COMA style_item:s
         {:
            l.add(s);
            RESULT = l;
         :}

     | style_item:s
         {:
            ArrayList<Object> list = new ArrayList<>();
            list.add(s);
            RESULT = list;
         :}
;

style_item ::=
      STYLE_COLOR DOSPUNTOS color_value:c
      {: RESULT = new ColorStyle(c); :}

    | STYLE_BACKGROUND DOSPUNTOS color_value:c
      {: RESULT = new BackgroundStyle(c); :}

    | STYLE_SIZE DOSPUNTOS ENTERO:n
      {: RESULT = new TextSizeStyle(Integer.parseInt(n.toString())); :}

    | STYLE_FONT DOSPUNTOS font_value:f
      {: RESULT = new FontStyle(f); :}
;

font_value ::=
        MONO {: RESULT = "MONO"; :}
        | SANS_SERIF {: RESULT = "SANS_SERIF"; :}
        | CURSIVE {: RESULT = "CURSIVE"; :}
;

